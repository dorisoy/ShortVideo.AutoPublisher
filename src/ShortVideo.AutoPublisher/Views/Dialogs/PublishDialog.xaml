<ui:FluentWindow
    x:Class="ShortVideo.AutoPublisher.Views.Dialogs.PublishDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="发布视频"
    Width="500"
    Height="500"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock 
            Grid.Row="0"
            Text="发布视频"
            FontSize="20"
            FontWeight="SemiBold"
            Margin="0,0,0,24"/>

        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 视频信息 -->
                <ui:Card Margin="0,0,0,16" Padding="12">
                    <StackPanel>
                        <TextBlock Text="视频标题" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="VideoTitleText" Text="视频标题" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </ui:Card>

                <!-- 发布平台选择 -->
                <TextBlock Text="选择发布平台" Margin="0,0,0,12"/>
                <ui:Card Margin="0,0,0,16" Padding="12">
                    <StackPanel>
                        <CheckBox x:Name="DouyinCheckBox" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="抖音" Width="80"/>
                                <TextBlock x:Name="DouyinStatusText" Text="未登录" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="XiaohongshuCheckBox" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="小红书" Width="80"/>
                                <TextBlock x:Name="XiaohongshuStatusText" Text="未登录" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="BaijiahaoCheckBox" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="百家号" Width="80"/>
                                <TextBlock x:Name="BaijiahaoStatusText" Text="未登录" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="WeixinCheckBox" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="视频号" Width="80"/>
                                <TextBlock x:Name="WeixinStatusText" Text="未登录" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ToutiaoCheckBox">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="头条" Width="80"/>
                                <TextBlock x:Name="ToutiaoStatusText" Text="未登录" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </ui:Card>

                <!-- 定时发布 -->
                <TextBlock Text="发布时间" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton x:Name="ImmediateRadio" Content="立即发布" IsChecked="True" Margin="0,0,16,0"/>
                    <RadioButton x:Name="ScheduledRadio" Content="定时发布"/>
                </StackPanel>

                <StackPanel x:Name="SchedulePanel" Visibility="Collapsed" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DatePicker x:Name="ScheduleDatePicker" Grid.Column="0" Margin="0,0,8,0"/>
                        <ui:TextBox x:Name="ScheduleTimeTextBox" Grid.Column="1" PlaceholderText="HH:mm"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <ui:Button 
                Content="取消"
                Margin="0,0,8,0"
                Click="Cancel_Click"/>
            <ui:Button 
                Content="开始发布"
                Appearance="Primary"
                Click="Publish_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
