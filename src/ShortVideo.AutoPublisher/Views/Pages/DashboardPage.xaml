<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="仪表盘"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock
                FontSize="32"
                FontWeight="SemiBold"
                Text="仪表盘" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="系统概览和快捷操作" />
        </StackPanel>

        <!-- 统计卡片 -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,24"
            Orientation="Horizontal">
            <ui:CardControl Width="200" Icon="{ui:SymbolIcon Video24}">
                <ui:CardControl.Header>
                    <TextBlock FontSize="36" FontWeight="Bold" Text="{Binding ViewModel.TotalVideos}" />
                </ui:CardControl.Header>
                <TextBlock Text="视频总数" />
            </ui:CardControl>
            <ui:CardControl Width="200" Icon="{ui:SymbolIcon Send24}">
                <ui:CardControl.Header>
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="LimeGreen" Text="{Binding ViewModel.TodayPublished}" />
                </ui:CardControl.Header>
                <TextBlock Text="今日发布" />
            </ui:CardControl>
            <ui:CardControl Width="200" Icon="{ui:SymbolIcon Clock24}">
                <ui:CardControl.Header>
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="Orange" Text="{Binding ViewModel.PendingTasks}" />
                </ui:CardControl.Header>
                <TextBlock Text="待处理" />
            </ui:CardControl>
            <ui:CardControl Width="200" Icon="{ui:SymbolIcon Warning24}">
                <ui:CardControl.Header>
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="Red" Text="{Binding ViewModel.FailedTasks}" />
                </ui:CardControl.Header>
                <TextBlock Text="失败任务" />
            </ui:CardControl>
        </StackPanel>

        <!-- 快捷操作和平台状态 -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Margin="0,0,0,12"
                    FontWeight="SemiBold"
                    Text="快捷操作" />
                <StackPanel Orientation="Horizontal">
                    <ui:Button
                        Command="{Binding ViewModel.NavigateToAddVideoCommand}"
                        Content="添加视频"
                        Icon="{ui:SymbolIcon Add24}" />
                    <ui:Button
                        Command="{Binding ViewModel.NavigateToCreateTaskCommand}"
                        Content="创建任务"
                        Icon="{ui:SymbolIcon TaskListAdd24}" />
                    <ui:Button
                        Command="{Binding ViewModel.NavigateToManageAccountCommand}"
                        Content="管理账号"
                        Icon="{ui:SymbolIcon Person24}" />
                    <ui:Button
                        Appearance="Primary"
                        Command="{Binding ViewModel.OneClickPublishCommand}"
                        Content="一键发布"
                        Icon="{ui:SymbolIcon Flash24}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,12,0"
                        FontWeight="SemiBold"
                        Text="平台连接状态" />
                    <TextBlock Foreground="LimeGreen" Text="{Binding ViewModel.ConnectedAccounts, StringFormat={}{0} 已连接}" />
                    <TextBlock Margin="8,0" Text="/" />
                    <TextBlock Foreground="Orange" Text="{Binding ViewModel.ExpiredAccounts, StringFormat={}{0} 已过期}" />
                </StackPanel>
                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ViewModel.PlatformStatus}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,0" Orientation="Horizontal">
                                <Ellipse
                                    Width="8"
                                    Height="8"
                                    Margin="0,0,4,0"
                                    Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}" />
                                <TextBlock Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <!-- 最近任务 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <Grid>
                <TextBlock FontWeight="SemiBold" Text="最近任务" />
                <ui:Button
                    HorizontalAlignment="Right"
                    Appearance="Transparent"
                    Content="查看全部"
                    Icon="{ui:SymbolIcon ChevronRight24}" />
            </Grid>
        </StackPanel>

        <DataGrid
            Grid.Row="4"
            AutoGenerateColumns="False"
            ItemsSource="{Binding ViewModel.RecentTasks}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding VideoTitle}"
                    Header="视频标题" />
                <DataGridTextColumn
                    Width="120"
                    Binding="{Binding PlatformDisplayName}"
                    Header="目标平台" />
                <DataGridTextColumn
                    Width="100"
                    Binding="{Binding StatusDisplayName}"
                    Header="状态" />
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}"
                    Header="创建时间" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 状态栏 -->
        <Grid Grid.Row="5" Margin="0,16,0,0">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Info24" />
                <TextBlock
                    Margin="4,0,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding ViewModel.LastUpdateTime}" />
            </StackPanel>
            <ui:Button
                HorizontalAlignment="Right"
                Command="{Binding ViewModel.LoadDataCommand}"
                Content="刷新"
                Icon="{ui:SymbolIcon ArrowSync24}" />
        </Grid>
    </Grid>
</Page>
