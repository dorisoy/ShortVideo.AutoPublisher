<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.CookieSessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ShortVideo.AutoPublisher.ViewModels.Pages"
    Title="账号管理"
    d:DataContext="{d:DesignInstance vm:CookieSessionViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock 
                Grid.Column="0"
                Text="账号管理"
                FontSize="24"
                FontWeight="SemiBold"
                VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button 
                    Content="刷新状态"
                    Margin="0,0,8,0"
                    Command="{Binding RefreshAllStatusCommand}"/>
                <ui:Button 
                    Content="添加账号"
                    Appearance="Primary"
                    Command="{Binding AddAccountCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 账号列表 -->
        <ui:Card Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 平台筛选 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="平台筛选：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox 
                        Width="150"
                        SelectedItem="{Binding SelectedPlatformFilter}"
                        ItemsSource="{Binding PlatformFilters}"/>
                </StackPanel>

                <!-- 账号DataGrid -->
                <DataGrid 
                    Grid.Row="1"
                    ItemsSource="{Binding FilteredSessions}"
                    SelectedItem="{Binding SelectedSession}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="平台" Binding="{Binding Platform}" Width="100"/>
                        <DataGridTextColumn Header="账号名称" Binding="{Binding AccountName}" Width="150"/>
                        <DataGridTextColumn Header="账号ID" Binding="{Binding AccountId}" Width="150"/>
                        <DataGridTemplateColumn Header="状态" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse 
                                            Width="8" Height="8" 
                                            Margin="0,0,6,0"
                                            Fill="{Binding IsValid, Converter={StaticResource BoolToColorConverter}}"/>
                                        <TextBlock Text="{Binding IsValid, Converter={StaticResource BoolToStatusConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="最后验证时间" Binding="{Binding LastValidatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                        <DataGridTemplateColumn Header="操作" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button 
                                            Content="验证"
                                            Appearance="Secondary"
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.ValidateSessionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                        <ui:Button 
                                            Content="更新Cookie"
                                            Appearance="Secondary"
                                            Margin="0,0,4,0"
                                            Command="{Binding DataContext.UpdateCookieCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                        <ui:Button 
                                            Content="删除"
                                            Appearance="Danger"
                                            Command="{Binding DataContext.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 空状态提示 -->
                <StackPanel 
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding HasNoSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock 
                        Text="暂无账号"
                        FontSize="16"
                        Margin="0,12,0,4"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="点击[添加账号]按钮添加平台账号"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</Page>
