<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:ShortVideo.AutoPublisher.ViewModels.Pages"
    Title="设置"
    d:DataContext="{d:DesignInstance vm:SettingsViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <!-- 页面标题 -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock 
                    Text="设置"
                    FontSize="32"
                    FontWeight="SemiBold"
                    Foreground="White"/>
                <TextBlock 
                    Text="配置应用程序的网络、浏览器和存储选项"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 网络设置 -->
            <ui:CardExpander IsExpanded="True" Margin="0,0,0,12">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Globe24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="网络设置" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="请求超时（秒）：" VerticalAlignment="Center"/>
                            <ui:NumberBox 
                                Grid.Column="1"
                                Value="{Binding NetworkTimeoutSeconds, Mode=TwoWay}"
                                Minimum="5"
                                Maximum="300"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="重试次数：" VerticalAlignment="Center"/>
                            <ui:NumberBox 
                                Grid.Column="1"
                                Value="{Binding RetryCount, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="10"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="代理地址：" VerticalAlignment="Center"/>
                            <ui:TextBox 
                                Grid.Column="1"
                                Text="{Binding ProxyAddress, Mode=TwoWay}"
                                PlaceholderText="例如：http://127.0.0.1:7890"
                                Width="300"
                                HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- 浏览器设置 -->
            <ui:CardExpander IsExpanded="True" Margin="0,0,0,12">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Window24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="浏览器设置" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="浏览器类型：" VerticalAlignment="Center"/>
                            <ComboBox 
                                Grid.Column="1"
                                SelectedItem="{Binding BrowserType}"
                                ItemsSource="{Binding BrowserTypes}"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="无头模式：" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch 
                                Grid.Column="1"
                                IsChecked="{Binding IsHeadless, Mode=TwoWay}"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="用户数据目录：" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:TextBox 
                                    Text="{Binding UserDataDir, Mode=TwoWay}"
                                    Width="300"
                                    Margin="0,0,8,0"/>
                                <ui:Button 
                                    Content="浏览"
                                    Icon="{ui:SymbolIcon Folder24}"
                                    Command="{Binding BrowseUserDataDirCommand}"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="最大并发数：" VerticalAlignment="Center"/>
                            <ui:NumberBox 
                                Grid.Column="1"
                                Value="{Binding MaxConcurrentBrowsers, Mode=TwoWay}"
                                Minimum="1"
                                Maximum="10"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- OpenClaw AI代理设置 -->
            <ui:CardExpander IsExpanded="True" Margin="0,0,0,12">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Bot24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OpenClaw AI代理" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="启用AI代理：" VerticalAlignment="Center"/>
                            <ui:ToggleSwitch 
                                Grid.Column="1"
                                IsChecked="{Binding IsAiAgentEnabled, Mode=TwoWay}"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="任务超时（分钟）：" VerticalAlignment="Center"/>
                            <ui:NumberBox 
                                Grid.Column="1"
                                Value="{Binding TaskTimeoutMinutes, Mode=TwoWay}"
                                Minimum="1"
                                Maximum="60"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="失败重试次数：" VerticalAlignment="Center"/>
                            <ui:NumberBox 
                                Grid.Column="1"
                                Value="{Binding AgentRetryCount, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="5"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- 存储设置 -->
            <ui:CardExpander IsExpanded="True" Margin="0,0,0,12">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Archive24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="存储设置" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="数据库路径：" VerticalAlignment="Center"/>
                            <TextBlock 
                                Grid.Column="1" 
                                Text="{Binding DatabasePath}"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="下载目录：" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:TextBox 
                                    Text="{Binding DownloadPath, Mode=TwoWay}"
                                    Width="300"
                                    Margin="0,0,8,0"/>
                                <ui:Button 
                                    Content="浏览"
                                    Icon="{ui:SymbolIcon Folder24}"
                                    Command="{Binding BrowseDownloadPathCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- 日志设置 -->
            <ui:CardExpander IsExpanded="False" Margin="0,0,0,12">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Document24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="日志设置" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日志级别：" VerticalAlignment="Center"/>
                            <ComboBox 
                                Grid.Column="1"
                                SelectedItem="{Binding LogLevel}"
                                ItemsSource="{Binding LogLevels}"
                                Width="150"
                                HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日志目录：" VerticalAlignment="Center"/>
                            <TextBlock 
                                Grid.Column="1" 
                                Text="{Binding LogPath}"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- 关于 -->
            <ui:CardExpander IsExpanded="False" Margin="0,0,0,24">
                <ui:CardExpander.Icon>
                    <ui:SymbolIcon Symbol="Info24" />
                </ui:CardExpander.Icon>
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="关于" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardExpander.Header>
                <ui:CardExpander.Content>
                    <StackPanel Margin="12">
                        <TextBlock Text="短视频自动发布工具" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="基于 WPF-UI 构建的多平台短视频自动发布工具" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </ui:CardExpander.Content>
            </ui:CardExpander>

            <!-- 保存按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button 
                    Content="重置默认"
                    Icon="{ui:SymbolIcon ArrowReset24}"
                    Margin="0,0,8,0"
                    Command="{Binding ResetToDefaultCommand}"/>
                <ui:Button 
                    Content="保存设置"
                    Icon="{ui:SymbolIcon Save24}"
                    Appearance="Primary"
                    Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
