<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.VideoManagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="视频库"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d"
    Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="32"
                       FontWeight="SemiBold"
                       Text="视频库"
                       Foreground="White" />
            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="管理您的视频内容，支持搜索、编辑和一键发布到多平台" />
        </StackPanel>

        <!-- 工具栏 -->
        <ui:Card Grid.Row="1" Margin="0,0,0,16" Padding="12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <ui:TextBox
                        Width="300"
                        Icon="{ui:SymbolIcon Search24}"
                        PlaceholderText="搜索视频标题或标签..."
                        Text="{Binding ViewModel.SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Icon="{ui:SymbolIcon Search24}"
                        Command="{Binding ViewModel.SearchCommand}"
                        Content="搜索" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <ui:Button
                        Margin="0,0,8,0"
                        Icon="{ui:SymbolIcon ArrowSync24}"
                        Command="{Binding ViewModel.LoadDataCommand}"
                        Content="刷新" />
                    <ui:Button
                        Appearance="Primary"
                        Icon="{ui:SymbolIcon Add24}"
                        Content="添加视频"
                        Click="ShowAddVideoDialog_Click" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- 视频列表 -->
        <DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            IsReadOnly="True"
            ItemsSource="{Binding ViewModel.Videos}"
            SelectedItem="{Binding ViewModel.SelectedVideo}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Binding="{Binding Title, Mode=OneWay}" Header="视频标题" />
                <DataGridTextColumn Width="150" Binding="{Binding Tags, Mode=OneWay}" Header="标签" />
                <DataGridTextColumn Width="100" Binding="{Binding FormattedFileSize, Mode=OneWay}" Header="文件大小" />
                <DataGridTextColumn Width="150" Binding="{Binding CreatedAt, Mode=OneWay, StringFormat=yyyy-MM-dd HH:mm}" Header="创建时间" />
                <DataGridTemplateColumn Width="280" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Appearance="Info"
                                    Icon="{ui:SymbolIcon Play24}"
                                    Command="{Binding DataContext.ViewModel.PreviewVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Content="预览" />
                                <ui:Button
                                    Margin="4,0,0,0"
                                    Appearance="Primary"
                                    Icon="{ui:SymbolIcon Send24}"
                                    Content="发布" />
                                <ui:Button
                                    Margin="4,0,0,0"
                                    Icon="{ui:SymbolIcon Edit24}"
                                    Content="编辑" />
                                <ui:Button
                                    Margin="4,0,0,0"
                                    Appearance="Danger"
                                    Icon="{ui:SymbolIcon Delete24}"
                                    Command="{Binding DataContext.ViewModel.DeleteVideoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}"
                                    Content="删除" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
