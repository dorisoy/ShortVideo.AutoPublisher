<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.PublishTaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="发布任务"
    Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="32"
                       FontWeight="SemiBold"
                       Text="发布任务"
                       Foreground="White" />
            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="查看和管理视频发布任务，监控发布进度" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,24" Orientation="Horizontal">
            <ui:CardControl Width="160" Margin="0,0,12,0">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Clock24" FontSize="28" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding PendingCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="等待中" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>
            <ui:CardControl Width="160" Margin="0,0,12,0">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Play24" FontSize="28" Foreground="DeepSkyBlue"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="DeepSkyBlue" Text="{Binding RunningCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="执行中" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>
            <ui:CardControl Width="160" Margin="0,0,12,0">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Checkmark24" FontSize="28" Foreground="LimeGreen"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="LimeGreen" Text="{Binding CompletedCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="已完成" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>
            <ui:CardControl Width="160" Margin="0,0,12,0">
                <ui:CardControl.Icon>
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="28" Foreground="Red"/>
                </ui:CardControl.Icon>
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="Red" Text="{Binding FailedCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="失败" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </ui:CardControl>
            <ui:Button 
                Appearance="Primary" 
                Icon="{ui:SymbolIcon ArrowSync24}"
                Command="{Binding LoadDataCommand}" 
                Content="刷新" 
                VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding Tasks}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="60" Binding="{Binding Id, Mode=OneWay}" Header="ID" />
                <DataGridTextColumn Width="*" Binding="{Binding VideoTitle, Mode=OneWay}" Header="视频标题" />
                <DataGridTextColumn Width="100" Binding="{Binding PlatformDisplayName, Mode=OneWay}" Header="平台" />
                <DataGridTextColumn Width="80" Binding="{Binding StatusDisplayName, Mode=OneWay}" Header="状态" />
                <DataGridTextColumn Width="60" Binding="{Binding Progress, Mode=OneWay, StringFormat={}{0}%}" Header="进度" />
                <DataGridTextColumn Width="150" Binding="{Binding CreatedAt, Mode=OneWay, StringFormat=yyyy-MM-dd HH:mm}" Header="创建时间" />
                <DataGridTemplateColumn Width="200" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button 
                                    Appearance="Info" 
                                    Icon="{ui:SymbolIcon Info24}"
                                    Command="{Binding DataContext.ViewTaskDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                    CommandParameter="{Binding}" 
                                    Content="详情" />
                                <ui:Button 
                                    Margin="4,0,0,0" 
                                    Icon="{ui:SymbolIcon ArrowSync24}"
                                    Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                    CommandParameter="{Binding}" 
                                    Content="重试" 
                                    IsEnabled="{Binding CanRetry}" />
                                <ui:Button 
                                    Margin="4,0,0,0" 
                                    Appearance="Danger" 
                                    Icon="{ui:SymbolIcon Dismiss24}"
                                    Command="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" 
                                    CommandParameter="{Binding}" 
                                    Content="取消" 
                                    IsEnabled="{Binding CanCancel}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
