<Page
    x:Class="ShortVideo.AutoPublisher.Views.Pages.PublishTaskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="发布任务"
    Loaded="Page_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock FontSize="32" FontWeight="SemiBold" Text="发布任务" />
            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="查看和管理视频发布任务，监控发布进度" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,24" Orientation="Horizontal">
            <ui:CardControl Width="150">
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding ViewModel.PendingCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="等待中" />
            </ui:CardControl>
            <ui:CardControl Width="150">
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="DeepSkyBlue" Text="{Binding ViewModel.RunningCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="执行中" />
            </ui:CardControl>
            <ui:CardControl Width="150">
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="LimeGreen" Text="{Binding ViewModel.CompletedCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="已完成" />
            </ui:CardControl>
            <ui:CardControl Width="150">
                <ui:CardControl.Header>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="Red" Text="{Binding ViewModel.FailedCount}" />
                </ui:CardControl.Header>
                <TextBlock Text="失败" />
            </ui:CardControl>
            <ui:Button Appearance="Primary" Command="{Binding ViewModel.LoadDataCommand}" Content="刷新" Icon="{ui:SymbolIcon ArrowSync24}" />
        </StackPanel>

        <DataGrid Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding ViewModel.Tasks}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="60" Binding="{Binding Id}" Header="ID" />
                <DataGridTextColumn Width="*" Binding="{Binding VideoTitle}" Header="视频标题" />
                <DataGridTextColumn Width="100" Binding="{Binding PlatformDisplayName}" Header="平台" />
                <DataGridTextColumn Width="80" Binding="{Binding StatusDisplayName}" Header="状态" />
                <DataGridTextColumn Width="60" Binding="{Binding Progress, StringFormat={}{0}%}" Header="进度" />
                <DataGridTextColumn Width="150" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Header="创建时间" />
                <DataGridTemplateColumn Width="200" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Appearance="Info" Command="{Binding DataContext.ViewModel.ViewTaskDetailCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Content="详情" />
                                <ui:Button Margin="4,0,0,0" Command="{Binding DataContext.ViewModel.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Content="重试" IsEnabled="{Binding CanRetry}" />
                                <ui:Button Margin="4,0,0,0" Appearance="Danger" Command="{Binding DataContext.ViewModel.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Content="取消" IsEnabled="{Binding CanCancel}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
